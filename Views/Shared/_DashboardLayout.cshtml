@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

@section Styles {
    @RenderSection("Styles", required: false)
}

@section Scripts {
    @RenderSection("Scripts", required: false)
}

<div class="sidebar">

    <div class="logo">
        RMS
    </div>

    <div class="sidebar-menu">

        <!-- MAKER -->
        @if (User.IsInRole("Maker"))
        {
            <a asp-controller="Maker" asp-action="Dashboard"
               class="@(currentController == "Maker" && currentAction == "Dashboard" ? "active" : "")">
                <i class="bi bi-speedometer2"></i>
                Dashboard
            </a>

            <a asp-controller="Maker" asp-action="Register"
               class="@(currentController == "Maker" && currentAction == "Register" ? "active" : "")">
                <i class="bi bi-pencil-square"></i>
                Register
            </a>

            <a asp-controller="Maker" asp-action="View"
               class="@(currentController == "Maker" && currentAction == "ViewRecord" ? "active" : "")">
                <i class="bi bi-eye"></i>
                View
            </a>
        }

        <!-- CHECKER -->
        @if (User.IsInRole("Checker"))
        {
            <a asp-controller="Checker" asp-action="Record"
               class="@(currentController == "Checker" && currentAction == "Record" ? "active" : "")">
                <i class="bi bi-journal-text"></i>
                Record
            </a>

            <a asp-controller="Checker" asp-action="Report"
               class="@(currentController == "Checker" && currentAction == "Report" ? "active" : "")">
                <i class="bi bi-file-earmark-bar-graph"></i>
                Reports
            </a>
        }

        <!-- ADMIN -->
        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Admin" asp-action="Users"
               class="@(currentController == "Admin" && currentAction == "Users" ? "active" : "")">
                <i class="bi bi-people"></i>
                Users
            </a>
        }

    </div>

</div>

<div class="main-content">

    <div class="topbar">

        <h5 class="mb-0">
            @ViewBag.Title
        </h5>

        <div class="dropdown">

            <button class="profile-btn" type="button" data-bs-toggle="dropdown">

                <div class="profile-avatar">
                    @(string.IsNullOrEmpty(User.Identity?.Name)
                        ? "U"
                        : User.Identity.Name.Substring(0, 1).ToUpper())
                </div>

            </button>

            <ul class="dropdown-menu dropdown-menu-end">

                <li>
                   @*  <a class="dropdown-item" href="/Profile">
                        <i class="bi bi-person"></i>
                        My Profile
                    </a> *@
                    <a class="dropdown-item" asp-controller="Maker" asp-action="Profile">
                        <i class="bi bi-person"></i>
                        My Profile
                    </a>
                </li>

                <li>
                    <hr class="dropdown-divider">
                </li>

                <li>
                    <a class="dropdown-item text-danger" href="/Logout">
                        <i class="bi bi-box-arrow-right"></i>
                        Logout
                    </a>
                </li>

            </ul>

        </div>

    </div>

    <div class="page-content">
        @RenderBody()
    </div>

</div>

<footer class="border-top text-center py-3 mt-auto">
    <small class="text-muted">
        © @DateTime.Now.Year Risk Management System. All rights reserved.
    </small>
</footer>

