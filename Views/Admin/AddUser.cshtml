@model RiskManagement.Account.Models.User

@{
    ViewBag.Title = "Add User";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles {
    <link href="~/css/adduser.css" rel="stylesheet" />
}
<div class="container-fluid">

    <div class="card shadow-sm border-0">

        <div class="card-header bg-white">
            <h3 class="mb-0">
                <i class="bi bi-person-plus-fill text-primary me-2"></i>
                Add New User
            </h3>
            <small class="text-muted">
                Create a new system user and assign the appropriate role.
            </small>
        </div>

        <div class="card-body">

            <form id="addUserForm">

                <div class="row">

                    <!-- Full Name -->
                    <div class="input-group">

                        <span class="input-group-text">
                            <i class="bi bi-person"></i>
                        </span>

                        <input asp-for="FullName" class="form-control" placeholder="Enter full name" />

                    </div>

                    <!-- Email -->
                    <div class="input-group">

                        <span class="input-group-text">
                            <i class="bi bi-envelope-fill"></i>
                        </span>

                        <input asp-for="Email" class="form-control" placeholder="example@company.com" />

                    </div>

                    <!-- Phone -->
                    <div class="input-group">

                        <span class="input-group-text">
                            <i class="bi bi-telephone-fill"></i>
                        </span>

                        <input asp-for="Phone" class="form-control" placeholder="+2519XXXXXXXX" />

                    </div>

                    <!-- Role -->
                    <div class="input-group">

                        <span class="input-group-text">
                            <i class="bi bi-person-badge-fill"></i>
                        </span>

                        <select asp-for="Role" class="form-select">

                            <option value="">Select Role</option>

                            <option value="Admin">Admin</option>
                            <option value="Maker">Maker</option>
                            <option value="Checker">Checker</option>

                        </select>

                    </div>

                    <!-- Status -->
                    <div class="mb-3">

                        <label class="form-label fw-semibold">
                            Status
                        </label>

                        <div class="form-check form-switch">

                            <input asp-for="Status" class="form-check-input" type="checkbox" id="statusToggle" value="1"
                                   checked />

                            <label class="form-check-label" for="statusToggle">
                                Active
                            </label>

                        </div>

                    </div>

                </div>

                <hr />

                <div class="d-flex justify-content-end gap-2">

                    <button type="reset" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>
                        Reset
                    </button>

                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-floppy-fill me-1"></i>
                        Save User
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/admin/adduser.js"></script>
}