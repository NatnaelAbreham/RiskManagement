@model RiskManagement.Account.Models.User

@{
    ViewBag.Title = @User.Identity.Name;
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles {
    <link href="~/css/adduser.css" rel="stylesheet" />
}
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/adduser.js"></script>
}
<div class="container-fluid">

    <div class="card shadow-sm border-0">

        <div class="card-header bg-white">
            <h3 class="mb-0">
                <i class="bi bi-person-plus-fill text-success me-2"></i>
                Add New User
            </h3>
            <small class="text-muted">
                Create a new system user and assign the appropriate role.
            </small>
        </div>

        <div class="card-body">

            <form id="addUserForm">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-4">

                    <!-- Full Name -->
                    <div class="col-md-6">

                        <label asp-for="FullName" class="form-label fw-semibold"></label>

                        <div class="input-group">

                            <span class="input-group-text">
                                <i class="bi bi-person-fill"></i>
                            </span>

                            <input asp-for="FullName" class="form-control" placeholder="Enter full name"
                                   autocomplete="name" required />

                        </div>

                        <span asp-validation-for="FullName" class="text-danger"></span>

                    </div>

                    <!-- Email -->
                    <div class="col-md-6">

                        <label asp-for="Email" class="form-label fw-semibold"></label>

                        <div class="input-group">

                            <span class="input-group-text">
                                <i class="bi bi-envelope-fill"></i>
                            </span>

                            <input asp-for="Email" class="form-control" placeholder="example@tsedeybank.com"
                                   autocomplete="email" required />

                        </div>

                        <span asp-validation-for="Email" class="text-danger"></span>

                    </div>

                    <!-- Phone -->
                    <div class="col-md-6">

                        <label asp-for="Phone" class="form-label fw-semibold"></label>

                        <div class="input-group">

                            <span class="input-group-text">
                                <i class="bi bi-telephone-fill"></i>
                            </span>

                            <input asp-for="Phone" class="form-control" placeholder="+2519XXXXXXXX"
                                   autocomplete="tel" required />

                        </div>

                        <span asp-validation-for="Phone" class="text-danger"></span>

                    </div>

                    <!-- Role -->
                    <div class="col-md-6">

                        <label asp-for="Role" class="form-label fw-semibold"></label>

                        <div class="input-group">

                            <span class="input-group-text">
                                <i class="bi bi-person-badge-fill"></i>
                            </span>

                            <select asp-for="Role" class="form-select" required>

                                <option value="">Select Role</option>
                                <option value="Admin">Admin</option>
                                <option value="Maker">Maker</option>
                                <option value="Checker">Checker</option>

                            </select>

                        </div>

                        <span asp-validation-for="Role" class="text-danger"></span>

                    </div>

                    <!-- Status -->
                    <div class="col-md-6">

                        <label class="form-label fw-semibold">Status</label>

                        <div class="form-check form-switch mt-2">

                            <input asp-for="Status" class="form-check-input" type="checkbox" id="statusToggle" value="1"
                                   checked />

                            <label class="form-check-label ms-2" for="statusToggle">
                                Active
                            </label>

                        </div>

                    </div>

                </div>

                <hr class="my-4" />

                <div class="d-flex justify-content-end gap-2">

                    <button type="reset" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>
                        Reset
                    </button>

                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-floppy-fill me-1"></i>
                        Save User
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

