@{
    ViewBag.Title = @User.Identity.Name;
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}
@section Styles {
    <link href="~/css/view.css" rel="stylesheet" />
}
@section Scripts {
    <script src="~/js/edituser.js"></script>
}
@model List<RiskManagement.Account.Models.User>


<div class="card shadow-lg p-4">
    <div class="card-header bg-transparent border-0 py-3">
        <div class="d-flex justify-content-between align-items-center">
            <h4 class="fw-bold mb-0">
                <i class="bi bi-bi bi-people text-success me-2"></i>
                Users
            </h4>
        </div>
    </div>
    <div class="table-responsive">

        @if (Model != null && Model.Any())
        {
            <table class="table table-hover table-bordered text-center align-middle" id="dataTable">
                <thead class="table-primary">
                    <tr>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Role</th>
                        <th>View</th>
                        <th>Edit</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {

                        foreach (var user in Model)
                        {
                            <tr>
                                <td>@user.FullName</td>
                                <td>@user.Email</td>
                                <td>@user.Phone</td>
                                <td>@user.Role</td>
                                <td>
                                   <button class="btn btn-outline-success view-btn"
                                      data-user='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(user))'>
                                     <i class="bi bi-eye-fill"></i>
                                   </button>
                                </td>

                                <td>
                                   <button class="btn btn-outline-primary edit-btn"
                                      data-user='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(user))'>
                                    <i class="bi bi-pencil-square"></i>
                                   </button>
                                </td>                    
                      
                            </tr>                           
                }
            }
                    else
            {
                <tr>
                    <td colspan="5" class="text-muted">No data available</td>
                </tr>
            }
        </tbody>
    </table>

}
        else
{

    <h6 colspan="5" class="text-muted">No data available!</h6>

}
</div>
</div>


<!-- ================= Edit User Profile Modal ================= -->
<div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">

        <div class="modal-content profile-modal">

            <!-- Close -->
            <button type="button"
                    class="btn-close profile-close"
                    data-bs-dismiss="modal"></button>

            <!-- Profile Header -->
            <div class="profile-header">

                <div class="profile-avatar" id="profileAvatar">
                    NA
                </div>

                <h3 id="profileName">User Name</h3>

                <p id="profileEmail">
                    user@email.com
                </p>

                <small>
                    Update profile information and account settings
                </small>

            </div>

            <!-- Body -->
            <div class="modal-body">

                <div class="row g-4"
                     id="editModalContent">

                </div>

            </div>

            <!-- Footer -->
            <div class="modal-footer profile-footer"
                 id="editModalFooter">

            </div>

        </div>

    </div>
</div>
      