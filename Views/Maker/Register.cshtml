@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewBag.Title = User.Identity.Name;
}

@section Styles {
    <link href="~/css/register.css" rel="stylesheet" />
    <!-- Font Awesome for icons (optional) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
}

<div class="card border-0 shadow-sm p-4">

    <!-- ========== PAGE HEADER ========== -->
    <div class="page-header">
        <h2>
            <i class="fas fa-clipboard-list" style="color: var(--primary);"></i>
            Risk Registration
            <span class="badge">New</span>
        </h2>
        <p>
            Register and document identified risks for comprehensive assessment, monitoring, and mitigation planning.
        </p>
    </div>

    <!-- ========== PROGRESS INDICATOR ========== -->
    <div class="form-progress">
        <div class="step active"></div>
        <div class="step"></div>
        <div class="step"></div>
        <div class="step"></div>
        <div class="step"></div>
    </div>

    <form>

        <!-- ============================================================ -->
        <!-- SECTION 1: RISK INFORMATION                                   -->
        <!-- ============================================================ -->
        <div class="form-section">

            <div class="row g-4">

                <div class="col-lg-3 col-md-6">
                    <label class="form-label required-field">
                        <i class="far fa-calendar-alt" style="color: var(--gray-400); margin-right: 4px;"></i>
                        Risk Date
                    </label>
                    <input type="date" class="form-control modern-input" required />
                </div>

                <div class="col-lg-3 col-md-6">
                    <label class="form-label required-field">
                        <i class="fas fa-tag" style="color: var(--gray-400); margin-right: 4px;"></i>
                        Identified Risk
                    </label>
                    <select class="form-select modern-input" required>
                        <option value="">Select Risk</option>
                        <option>Domestic Banking</option>
                        <option>Credit Operation</option>
                        <option>International Banking</option>
                        <option>Investment Portfolio</option>
                        <option>Compliance & Regulatory</option>
                    </select>
                </div>

                <div class="col-lg-3 col-md-6">
                    <label class="form-label required-field">
                        <i class="fas fa-search" style="color: var(--gray-400); margin-right: 4px;"></i>
                        Source of Risk
                    </label>
                    <input type="text" class="form-control modern-input" placeholder="e.g. Client feedback, Audit, Process" required />
                </div>

                <div class="col-lg-3 col-md-6">
                    <label class="form-label required-field">
                        <i class="fas fa-folder" style="color: var(--gray-400); margin-right: 4px;"></i>
                        Risk Category
                    </label>
                    <select class="form-select modern-input" required>
                        <option value="">Select Category</option>
                        <option>Internal Fraud</option>
                        <option>External Fraud</option>
                        <option>Employment & Workplace Safety</option>
                        <option>Property Damage</option>
                        <option>System Failure & Business Disruption</option>
                        <option>Process Management & Execution</option>
                        <option>Customer & Product Risk</option>
                    </select>
                </div>

                <div class="col-12">
                    <label class="form-label required-field">
                        <i class="fas fa-exclamation-triangle" style="color: var(--gray-400); margin-right: 4px;"></i>
                        Risk Event Description
                    </label>
                    <textarea class="form-control modern-input" 
                              placeholder="Provide a comprehensive description of the identified risk event, including context, triggers, and potential consequences…" 
                              required></textarea>
                    <span class="field-helper">
                        <i class="far fa-comment"></i> Be specific about the nature, scope, and potential impact of the risk.
                    </span>
                </div>

            </div>

        </div>

        <!-- ============================================================ -->
        <!-- SECTION 2: RISK ASSESSMENT                                   -->
        <!-- ============================================================ -->
        <div class="form-section">
            <div class="row g-4">

                <div class="col-lg-3 col-md-6">
                    <label class="form-label required-field">
                        <i class="fas fa-bullseye" style="color: var(--gray-400); margin-right: 4px;"></i>
                        Effect
                    </label>
                    <input type="text" class="form-control modern-input" placeholder="e.g. Financial, Operational, Reputational" required />
                </div>

                <div class="col-lg-3 col-md-6">
                    <label class="form-label required-field">
                        <i class="fas fa-percent" style="color: var(--gray-400); margin-right: 4px;"></i>
                        Probability (%)
                    </label>
                    <input type="number" class="form-control modern-input" placeholder="0-100" min="0" max="100" required />
                </div>

                <div class="col-lg-3 col-md-6">
                    <label class="form-label required-field">
                        <i class="fas fa-arrow-up" style="color: var(--gray-400); margin-right: 4px;"></i>
                        Impact Level
                    </label>
                    <select class="form-select modern-input" required>
                        <option value="">Select Impact</option>
                        <option>Low</option>
                        <option>Medium</option>
                        <option>High</option>
                        <option>Critical</option>
                    </select>
                </div>

                <div class="col-lg-3 col-md-6">
                    <label class="form-label required-field">
                        <i class="fas fa-calculator" style="color: var(--gray-400); margin-right: 4px;"></i>
                        Risk Score
                    </label>
                    <input type="number" class="form-control modern-input" placeholder="Calculated score" step="0.01" required />
                    <span class="field-helper">Probability × Impact</span>
                </div>

                <div class="col-lg-6 col-md-6">
                    <label class="form-label required-field">
                        <i class="fas fa-gauge-high" style="color: var(--gray-400); margin-right: 4px;"></i>
                        Risk Rating
                    </label>
                    <select class="form-select modern-input" required>
                        <option value="">Select Rating</option>
                        <option>Low</option>
                        <option>Medium</option>
                        <option>High</option>
                        <option>Extreme</option>
                    </select>
                </div>

                <div class="col-lg-6 col-md-6">
                    <label class="form-label required-field">
                        <i class="fas fa-shield" style="color: var(--gray-400); margin-right: 4px;"></i>
                        Residual Risk Level
                    </label>
                    <select class="form-select modern-input" required>
                        <option value="">Select Residual Risk</option>
                        <option>Low</option>
                        <option>Medium</option>
                        <option>High</option>
                        <option>Extreme</option>
                    </select>
                    <span class="field-helper">After applying existing controls</span>
                </div>

            </div>

        </div>

        <!-- ============================================================ -->
        <!-- SECTION 3: MITIGATION & CONTROLS                             -->
        <!-- ============================================================ -->
        <div class="form-section">
            <div class="row g-4">

                <div class="col-12">
                    <label class="form-label required-field">
                        <i class="fas fa-check-circle" style="color: var(--gray-400); margin-right: 4px;"></i>
                        Existing Risk Mitigation
                    </label>
                    <textarea class="form-control modern-input" 
                              placeholder="Describe all existing controls, safeguards, and mitigation measures currently in place…" 
                              required></textarea>
                    <span class="field-helper">Include both preventive and detective controls.</span>
                </div>

                <div class="col-lg-6">
                    <label class="form-label required-field">
                        <i class="fas fa-star" style="color: var(--gray-400); margin-right: 4px;"></i>
                        Mitigation Rating
                    </label>
                    <select class="form-select modern-input" required>
                        <option value="">Select Rating</option>
                        <option>Very Weak</option>
                        <option>Weak</option>
                        <option>Moderate</option>
                        <option>Strong</option>
                        <option>Very Strong</option>
                    </select>
                </div>

                <div class="col-lg-6">
                    <label class="form-label required-field">
                        <i class="fas fa-lightbulb" style="color: var(--gray-400); margin-right: 4px;"></i>
                        Recommendation
                    </label>
                    <textarea class="form-control modern-input" 
                              placeholder="Provide recommended actions to further mitigate or eliminate the risk…" 
                              required></textarea>
                </div>

            </div>

        </div>

        <!-- ============================================================ -->
        <!-- SECTION 4: OWNERSHIP & PLANNING                              -->
        <!-- ============================================================ -->
        <div class="form-section">

            <div class="row g-4">

                <div class="col-lg-4 col-md-6">
                    <label class="form-label required-field">
                        <i class="far fa-calendar-check" style="color: var(--gray-400); margin-right: 4px;"></i>
                        Mitigation Planned Date
                    </label>
                    <input type="date" class="form-control modern-input" required />
                </div>

                <div class="col-lg-4 col-md-6">
                    <label class="form-label required-field">
                        <i class="fas fa-user" style="color: var(--gray-400); margin-right: 4px;"></i>
                        Risk Owner
                    </label>
                    <input type="text" class="form-control modern-input" placeholder="Full name or role" required />
                    <span class="field-helper">Person responsible for managing this risk</span>
                </div>

                <div class="col-lg-4 col-md-6">
                    <label class="form-label">
                        <i class="fas fa-flag" style="color: var(--gray-400); margin-right: 4px;"></i>
                        Status
                    </label>
                    <select class="form-select modern-input">
                        <option>Open</option>
                        <option>In Progress</option>
                        <option>Closed</option>
                    </select>
                </div>

            </div>

        </div>

        <!-- ============================================================ -->
        <!-- ACTION BAR                                                   -->
        <!-- ============================================================ -->
        <div class="action-bar">
            <button type="reset" class="btn btn-outline-secondary">
                <i class="fas fa-undo-alt me-2"></i>Clear Form
            </button>
            <button type="submit" class="btn btn-success">
                <i class="fas fa-save me-2"></i>Register Risk
            </button>
        </div>

    </form>

</div>