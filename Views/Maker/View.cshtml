@{
    ViewBag.Title = @User.Identity.Name;
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@model List<RiskManagement.Models.RiskRegistration>


<div class="card shadow-lg p-4">
    <div class="card-header bg-transparent border-0 py-3">
        <div class="d-flex justify-content-between align-items-center">
            <h4 class="fw-bold mb-0">
                <i class="bi bi-shield-check text-success me-2"></i>
                Risk Records
            </h4>
        </div>
    </div>
    <div class="table-responsive">

        @if (Model != null && Model.Any())
        {
            <table class="table table-hover table-bordered text-center align-middle" id="dataTable">
                <thead class="table-success">
                    <tr>
                        <th>Risk ID</th>

                        <!-- Section 1: Risk Information -->
                        <th>Risk Date</th>
                        <th>Identified Risk</th>
                        <th>Source of Risk</th>
                        <th>Risk Category</th>
                        <th>Risk Event Description</th>

                        <!-- Section 2: Risk Assessment -->
                        <th>Effect</th>
                        <th>Probability</th>
                        <th>Impact Level</th>
                        <th>Risk Score</th>
                        <th>Risk Rating</th>
                        <th>Residual Risk Level</th>

                        <!-- Section 3: Mitigation & Controls -->
                        <th>Existing Risk Mitigation</th>
                        <th>Mitigation Rating</th>
                        <th>Recommendation</th>

                        <!-- Section 4: Ownership & Planning -->
                        <th>Mitigation Planned Date</th>
                        <th>Risk Owner</th>

                        <!-- Optional -->
                        <th>Status</th>
                        <th>Edit</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {

                        foreach (var user in Model)
                        {
                            @if (user.Status == "rejected")
                            {
                                continue;
                            }
                            <tr>

                                <td>@user.RiskId</td>

                                <!-- Section 1: Risk Information -->
                                <td>@user.RiskDate.ToString("yyyy-MM-dd")</td>
                                <td>@user.IdentifiedRisk</td>
                                <td>@user.SourceOfRisk</td>
                                <td>@user.RiskCategory</td>
                                <td>@user.RiskEventDescription</td>

                                <!-- Section 2: Risk Assessment -->
                                <td>@user.Effect</td>
                                <td>@user.Probability</td>
                                <td>@user.ImpactLevel</td>
                                <td>@user.RiskScore</td>
                                <td>@user.RiskRating</td>
                                <td>@user.ResidualRiskLevel</td>

                                <!-- Section 3: Mitigation & Controls -->
                                <td>@user.ExistingRiskMitigation</td>
                                <td>@user.MitigationRating</td>
                                <td>@user.Recommendation</td>

                                <!-- Section 4: Ownership & Planning -->
                                <td>@user.MitigationPlannedDate.ToString("yyyy-MM-dd")</td>
                                <td>@user.RiskOwner</td>
                                <td>
                                    @if (user.Status == "approved")
                                    {
                                        <span class="badge bg-success rounded-pill px-3 py-2">
                                            Approved
                                        </span>
                                    }
                                    else if (user.Status == "rejected")
                                    {
                                        <span class="badge bg-danger rounded-pill px-3 py-2">
                                            Rejected
                                        </span>
                                    }
                                    else
                                    {
                                        @* <i class="bi bi-dash text-muted"></i> *@
                                        <span class="badge bg-warning text-dark rounded-pill px-3 py-2">
                                            Pending
                                        </span>
                                    }
                                </td>

                                <td>

                                    @if (user.Status == "rejected" || user.Status == "pending")
                                    {
                                        <button class="btn btn-outline-success edit-btn"
                                                data-user='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(user))'>
                                            <i class="bi bi-pencil-square"></i>
                                        </button>

                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-success edit-btn"
                                                data-user='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(user))'>
                                            <i class="bi bi-eye-fill"></i>
                                        </button>

                                    }

                                           
                                       
                                </td>
                            </tr>

                                
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-muted">No data available</td>
                        </tr>
                    }
                </tbody>
            </table>

        }
        else
        {

            <h6 colspan="6" class="text-muted">No data available!</h6>

        }
    </div>
</div>


<!-- Modal Body -->
<div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editModalLabel">Edit Information</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row" id="editModalContent"></div>
            </div>
        </div>
    </div>
</div>

      