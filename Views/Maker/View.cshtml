@{
    ViewBag.Title = @User.Identity.Name;
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@model List<RiskManagement.Models.RiskRegistration>

<div class="container mt-5"> // mt mean Margin Top
    <div class="card shadow-lg p-4">// "card" create bootstrap card "p" padding and large box shadow
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4><i class="bi bi-table"></i> User Records</h4>
        </div>
        <div class="table-responsive">

            @if (Model != null && Model.Any())
            {
                <table class="table table-hover table-bordered text-center align-middle" id="dataTable">
                    <thead>
                        <tr>
                            <th>Risk ID</th>
                            <th>Name</th>
                            <th>balance</th>
                            <th>Importer TIN</th>
                            <th>Importer NBE acc</th>
                            <th>Verified</th>
                            <th>Approved</th>
                            <th>Edit</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {

                            foreach (var user in Model)
                            {
                                @if (user.Status == "rejected")
                                {
                                    continue;
                                }
                                <tr>

                                    <td>@user.QueueNumber</td>
                                    <td>@user.ImporterName</td>
                                    <td>@user.Balance</td>
                                    <td>@user.ImporterTIN</td>
                                    <td>@user.ImporterNBEAcc</td>

                                    <td>
                                        @if (user.Status == "approved")
                                        {
                                            <i class="bi bi-check-circle-fill text-success"></i>
                                        }
                                        else if (user.Status == "verified")
                                        {
                                            <i class="bi bi-check-circle-fill text-success"></i>
                                        }
                                        else if (user.Status == "rejected")
                                        {
                                            <i class="bi bi-x-circle-fill text-danger"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-dash text-muted"></i>
                                        }
                                    </td>
                                    <td>
                                        @if (user.Status == "approved")
                                        {
                                            <i class="bi bi-check-circle-fill text-success"></i>
                                        }
                                        else if (user.Status == "verified")
                                        {
                                            <i class="bi bi-dash text-muted"></i>
                                        }
                                        else if (user.Status == "rejected")
                                        {
                                            <i class="bi bi-x-circle-fill text-danger"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-dash text-muted"></i>
                                        }
                                    </td>
                                    <td>

                                        @if (user.Status == "rejected" || user.Status == "pending")
                                        {
                                            <button class="btn btn-outline-success edit-btn"
                                                    data-user='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(user))'>
                                                <i class="bi bi-pencil-square"></i>
                                            </button>

                                        }
                                        else
                                        {
                                            <button class="btn btn-outline-success edit-btn"
                                                    data-user='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(user))'>
                                                <i class="bi bi-eye-fill"></i>
                                            </button>

                                        }

                                           
                                       
                                    </td>
                                </tr>

                                
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-muted">No data available</td>
                            </tr>
                        }
                    </tbody>
                </table>

            }
            else
            {

                <h6 colspan="6" class="text-muted">No data available!</h6>

            }
        </div>
    </div>
</div>
      