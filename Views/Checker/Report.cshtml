@{
    ViewBag.Title = "Risk Reports";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Scripts {
    <script src="~/js/report.js"></script>
}
<div class="container-fluid">

    <h3 class="fw-bold mb-4">
        Risk Reports
    </h3>

    <!-- Filter Card -->
    <div class="card shadow-sm mb-4">

        <div class="card-header">
            <h5 class="mb-0">
                Filter Reports
            </h5>
        </div>

        <div class="card-body">

            <div class="row g-3">

                <div class="col-md-3">

                    <label class="form-label">
                        Identified Risk
                    </label>

                    <select id="identifiedRisk" class="form-select">

                        <option value="">
                            All
                        </option>

                    </select>

                </div>

                <div class="col-md-2">

                    <label class="form-label">
                        Status
                    </label>

                    <select id="status" class="form-select">

                        <option value="">All</option>
                        <option>pending</option>
                        <option>approved</option>
                        <option>rejected</option>

                    </select>

                </div>

                <div class="col-md-2">

                    <label class="form-label">
                        Risk Rating
                    </label>

                    <select id="rating" class="form-select">

                        <option value="">All</option>
                        <option>High</option>
                        <option>Medium</option>
                        <option>Low</option>

                    </select>

                </div>

                <div class="col-md-2">

                    <label class="form-label">
                        From
                    </label>

                    <input type="date" id="fromDate" class="form-control" required />

                </div>

                <div class="col-md-2">

                    <label class="form-label">
                        To
                    </label>

                    <input type="date" id="toDate" class="form-control" required />

                </div>

                <div class="col-md-2 d-flex align-items-end gap-2">
                    <button id="btnFilter" class="btn btn-success flex-fill">
                        Filter
                    </button>

                    <button id="btnReset" class="btn btn-outline-secondary">
                        Reset
                    </button>
                </div>

            </div>

        </div>

    </div>

    <!-- Export Buttons -->

    <div class="d-flex justify-content-end mb-3">
        <div class="btn-group" role="group" aria-label="Export options">
            <button id="btnCopy" class="btn btn-primary">
                <i class="bi bi-clipboard me-1"></i>
                Copy
            </button>
            <button id="btnExcel" type="button" class="btn btn-success">
                <i class="bi bi-file-earmark-excel me-1"></i>
                Excel
            </button>

            <button id="btnPdf" type="button" class="btn btn-danger">
                <i class="bi bi-file-earmark-pdf me-1"></i>
                PDF
            </button>

            <button id="btnPrint" type="button" class="btn btn-secondary">
                <i class="bi bi-printer me-1"></i>
                Print
            </button>

        </div>
    </div>

    <!-- Report Table -->

    <div class="card shadow-sm">

        <div class="card-body">

            <table id="dataTable" class="table table-bordered table-hover align-middle">

                <thead class="table-primary">

                    <tr>

                        <th>Risk ID</th>
                        <th>Date</th>
                        <th>Identified Risk</th>
                        <th>Category</th>
                        <th>Rating</th>
                        <th>Score</th>
                        <th>Status</th>
                        <th>Owner</th>

                    </tr>

                </thead>

                <tbody>

                </tbody>

            </table>

        </div>

    </div>
