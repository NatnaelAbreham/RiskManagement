@{
    ViewBag.Title = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";

}
@section Styles {
    <link href="~/css/login.css" rel="stylesheet" />
}

<body>

    <div class="container-fluid">
        <div class="row min-vh-100">

            <!-- Left Column (75%) -->
            <div class="col-md-9 bg-success text-white p-4">
                <h2>Left Column</h2>
                <p>This column takes 75% of the width.</p>
            </div>

            <!-- Right Column (25%) -->
            @*  <div class="col-md-3 bg-white p-4 border-start">
                <h2>Right Column</h2>
                <p>This column takes 25% of the width.</p>
            </div>  *@

              <div class="col-md-3  p-4 border-start login-container">
      <div class="login-card">
          <img src="./images/mike.png" width="300px" height="150" />

          <!-- Toggle Switch -->
          <div class="form-group mb-3 form-switch">
              <input type="checkbox" id="toggle" class="form-check-input" hidden />
              <label class="form-check-label ms-2" for="toggle" hidden>Disable Password Restrictions</label>
          </div>

          <form id="loginForm" method="post" action="/login">
              <div class="mb-3">
                  <input type="text"
                         class="form-control"
                         id="username"
                         placeholder="Email or Phone"
                         required />
              </div>
        
              <div class="mb-3">
                  <input type="password" class="form-control" id="password" placeholder="Password" required>
                  <small id="passwordError" class="text-danger"></small>
              </div>

              <button type="submit" class="btn btn-login">Log In</button>
              <br /><br />
              <div id="errormessage" class="alert alert-danger text-center d-none" role="alert"></div>

              <div class="forgot-password">
                  <a asp-controller ="Home" asp-action ="Reset" >Forgot Password?</a>
              </div>
          </form>
      </div>
  </div>



           

        </div>
    </div>
</body>